{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/admin(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/minhas-compras",
      "destination": "/index.html"
    },
    {
      "source": "/sucesso",
      "destination": "/index.html"
    },
    {
      "source": "/cancelado",
      "destination": "/index.html"
    },
    {
      "source": "/pendente",
      "destination": "/index.html"
    },
    {
      "source": "/:id",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
