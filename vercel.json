{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/api-seo/:id",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|admin|minhas-compras|sucesso|cancelado|pendente).*\\..*)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/router.ts"
    }
  ]
}
